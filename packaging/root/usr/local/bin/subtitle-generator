#!/bin/bash
# Subtitle Generator launcher
APP_DIR="/usr/local/subtitle-generator"

if ! command -v python3 >/dev/null 2>&1; then
  echo "Error: python3 is required but not found. Install Python 3 from https://python.org"
  exit 1
fi
if ! command -v ffmpeg >/dev/null 2>&1; then
  echo "Error: ffmpeg is required but not found. Install with: brew install ffmpeg"
  exit 1
fi

echo "Starting Subtitle Generator at http://localhost:8766"
echo "Press Ctrl+C to stop."
( sleep 2 && open http://localhost:8766 ) &
exec python3 "$APP_DIR/main.py"
